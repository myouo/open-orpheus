<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.yucling.open-orpheus</id>

  <name>Open Orpheus</name>
  <summary>Netease Cloud Music for Linux</summary>
  <summary xml:lang="zh-CN">Linux 版网易云音乐客户端</summary>
  <developer_name>YUCLing</developer_name>
  <developer id="io.github.yucling">
    <name translate="no">YUCLing</name>
  </developer>
  <url type="homepage">https://github.com/YUCLing/open-orpheus</url>
  <url type="vcs-browser">https://github.com/YUCLing/open-orpheus</url>
  <url type="bugtracker">https://github.com/YUCLing/open-orpheus/issues</url>
  <url type="contact">https://github.com/YUCLing/open-orpheus/discussions</url>
  <url type="contribute">https://github.com/YUCLing/open-orpheus/blob/main/CONTRIBUTING.md</url>

  <metadata_license>CC-BY-4.0</metadata_license>
  <project_license>MIT</project_license>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
    <control>tablet</control>
  </supports>

  <description>
    <p>**This app is only available in Chinese.**</p>
    <p>
      Open Orpheus is an open-source implementation of Netease Cloud Music browser host, it allows the user to run Netease Cloud Music official client's web resources on Linux, with the best compatibility provided by this host.
    </p>
    <p xml:lang="zh-CN">**本应用当前仅提供中文界面。**</p>
    <p xml:lang="zh-CN">
      Open Orpheus 是网易云音乐浏览器宿主的开源实现，让用户可以在 Linux 上运行网易云音乐官方客户端的网页资源，并提供尽可能好的兼容性。
    </p>
  </description>

  <launchable type="desktop-id">io.github.yucling.open-orpheus.desktop</launchable>

  <branding>
    <color type="primary" scheme_preference="light">#5A9EF5</color>
    <color type="primary" scheme_preference="dark">#2B4A73</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <caption>Main interface</caption>
      <caption xml:lang="zh-CN">主界面</caption>
      <image>https://raw.githubusercontent.com/YUCLing/open-orpheus/810d3d6010209e1cd0c81275a94341c00ff93d93/assets/screenshots/1.png</image>
    </screenshot>
    <screenshot>
      <caption>Player view</caption>
      <caption xml:lang="zh-CN">播放器界面</caption>
      <image>https://raw.githubusercontent.com/YUCLing/open-orpheus/810d3d6010209e1cd0c81275a94341c00ff93d93/assets/screenshots/2.png</image>
    </screenshot>
    <screenshot>
      <caption>Settings and customization</caption>
      <caption xml:lang="zh-CN">设置与个性化</caption>
      <image>https://raw.githubusercontent.com/YUCLing/open-orpheus/810d3d6010209e1cd0c81275a94341c00ff93d93/assets/screenshots/3.png</image>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.11.4" date="2026-05-12">
      <url type="details">https://github.com/YUCLing/open-orpheus/releases/tag/v0.11.4</url>
      <description>
        <ul>
          <li>Fixed third-party login.</li>
          <li xml:lang="zh-CN">修复第三方登录。</li>
          <li>Fixed User-Agent error on Linux.</li>
          <li xml:lang="zh-CN">修复 Linux 下 User-Agent 错误。</li>
        </ul>
      </description>
    </release>
    <release version="0.11.3" date="2026-05-11">
      <url type="details">https://github.com/YUCLing/open-orpheus/releases/tag/v0.11.3</url>
      <description>
        <ul>
          <li>Improved visibility of desktop lyrics unlock button on Linux.</li>
          <li xml:lang="zh-CN">提高 Linux 下桌面歌词解锁按钮可见度。</li>
        </ul>
      </description>
    </release>
    <release version="0.11.2" date="2026-05-10">
      <url type="details">https://github.com/YUCLing/open-orpheus/releases/tag/v0.11.2</url>
      <description>
        <ul>
          <li>Fix connection error when using HTTP proxy.</li>
          <li xml:lang="zh-CN">修复连接HTTP代理出错。</li>
          <li>Mini player now displays default cover when no music is loaded.</li>
          <li xml:lang="zh-CN">mini 播放器无音乐时没有显示默认封面（已修复）。</li>
        </ul>
      </description>
    </release>
    <release version="0.11.1" date="2026-05-10">
      <url type="details">https://github.com/YUCLing/open-orpheus/releases/tag/v0.11.1</url>
      <description>
        <ul>
          <li>Updated dependencies and Electron.</li>
          <li xml:lang="zh-CN">更新依赖和 Electron。</li>
        </ul>
      </description>
    </release>
    <release version="0.11.0" date="2026-05-10">
      <url type="details">https://github.com/YUCLing/open-orpheus/releases/tag/v0.11.0</url>
      <description>
        <ul>
          <li>Added mini player mode.</li>
          <li xml:lang="zh-CN">新增 mini 播放器模式。</li>
          <li>Added proxy support.</li>
          <li xml:lang="zh-CN">新增代理支持。</li>
          <li>Fixed downloaded track index not handling subdirectories.</li>
          <li xml:lang="zh-CN">修复已下载曲目索引无法处理子目录的问题。</li>
          <li>Fixed desktop lyrics not allowing mouse clicks when locked.</li>
          <li xml:lang="zh-CN">修复桌面歌词锁定后鼠标点击不穿透的问题。</li>
          <li>Fixed error when exiting while buffering.</li>
          <li xml:lang="zh-CN">修复缓冲时退出出现错误的问题。</li>
          <li>Changed Flatpak default download directory.</li>
          <li xml:lang="zh-CN">更改 Flatpak 默认下载目录。</li>
        </ul>
      </description>
    </release>
    <release version="0.10.4" date="2026-05-04">
      <url type="details">https://github.com/YUCLing/open-orpheus/releases/tag/v0.10.4</url>
      <description>
        <ul>
          <li>Fixed podcast download failure.</li>
          <li xml:lang="zh-CN">修复播客下载失败问题。</li>
        </ul>
      </description>
    </release>
    <release version="0.10.2" date="2026-05-04">
      <url type="details">https://github.com/YUCLing/open-orpheus/releases/tag/v0.10.2</url>
      <description>
        <ul>
          <li>Fixed cookie expiration time.</li>
          <li xml:lang="zh-CN">修复 Cookie 过期时间。</li>
        </ul>
      </description>
    </release>
    <release version="0.10.1" date="2026-05-04">
      <description>
        <p>Fixes Cookie management.</p>
        <p xml:lang="zh-CN">修复 Cookie 管理。</p>
      </description>
    </release>
    <release version="0.10.0" date="2026-05-04">
      <description>
        <p>Custom skin support; fix multiple request issues; update resource package to 3.1.32.</p>
        <p xml:lang="zh-CN">自定义换肤支持；修复多个请求问题；更新资源包到 3.1.32。</p>
      </description>
    </release>
    <release version="0.9.0" date="2026-05-03">
      <description>
        <p>Listen Together feature; new version check; fix downloaded MP3 files being saved with .ncm extension.</p>
        <p xml:lang="zh-CN">一起听功能；新版本检查；修复下载的 MP3 被保存为 NCM 后缀的问题。</p>
      </description>
    </release>
    <release version="0.8.0" date="2026-05-01">
      <description>
        <p>Allow custom download/cache paths; fix X11 window dragging; fix Shell API Windows path handling; enforce initial download directory selection in Flatpak.</p>
        <p xml:lang="zh-CN">允许自定义下载/缓存路径；修复 X11 窗口拖动问题；修复 Shell API 的 Windows 路径处理问题；强制在 Flatpak 中选择初始下载目录。</p>
      </description>
    </release>
    <release version="0.7.0" date="2026-04-29">
      <description>
        <p>Supports local music library, local music playback and music downloading.</p>
        <p xml:lang="zh-CN">支持本地音乐库、本地音乐播放、音乐下载</p>
      </description>
    </release>
    <release version="0.6.1" date="2026-04-26">
      <description>
        <p>Improved HTTP request mechanism. In hope of better performance and stability.</p>
        <p xml:lang="zh-CN">改进了 HTTP 请求机制，以期获得更好的性能和稳定性。</p>
      </description>
    </release>
    <release version="0.6.0" date="2026-04-24">
      <description>
        <p>Supports overriding main window size limits.</p>
        <p xml:lang="zh-CN">支持覆盖主窗口大小限制。</p>
      </description>
    </release>
    <release version="0.5.6" date="2026-04-24">
      <description>
        <p>Improved aarch64 support.</p>
        <p xml:lang="zh-CN">完善 aarch64 支持。</p>
      </description>
    </release>
    <release version="0.5.3" date="2026-04-21">
      <description>
        <p>Improved overall compatibility and stability for running Netease Cloud Music web resources on Linux.</p>
        <p xml:lang="zh-CN">提升了在 Linux 上运行网易云音乐网页资源时的整体兼容性与稳定性。</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">moderate</content_attribute>
    <content_attribute id="social-info">mild</content_attribute>
    <content_attribute id="money-purchasing">intense</content_attribute>
  </content_rating>
</component>
